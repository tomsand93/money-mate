{
  "comment": "Smart categorization rules - example configuration",
  "rules": {
    "ספורט וכושר": {
      "keywords": ["טיפוס", "climbing", "בולדר", "boulder", "gym", "fitness", "ספורט"],
      "patterns": ["*climb*", "*boulder*", "*gym*", "*sport*"]
    },
    "תחבורה": {
      "keywords": ["דלק", "פז", "סונול", "תחנת דלק", "חניה", "גט טקסי", "רכבת ישראל", "מוניות", "תדלוק"],
      "patterns": ["*דלק*", "*חניה*", "*taxi*", "*רכבת*"]
    },
    "אוכל בחוץ": {
      "keywords": ["קפה", "פלאפל", "מקדונלד", "בורגר", "פיצה", "רשת קפה", "מסעדה", "סושי", "restaurant", "cafe", "coffee"],
      "patterns": ["*קפה*", "*מסעדה*", "*restaurant*", "*bar*", "*burger*", "*pizza*"]
    },
    "סופרמרקט": {
      "keywords": ["שופרסל", "רמי לוי", "ויקטורי", "מחסני השוק", "יינות בי", "AM:PM", "מינימרקט", "מגה בעיר", "סופר", "market"],
      "patterns": ["*סופר*", "*market*", "*שוק*", "*מרקט*"]
    },
    "נסיעות וטיולים": {
      "keywords": ["טיסה", "מלון", "HOTEL", "BOOKING", "airbnb", "vacation", "travel", "flight"],
      "patterns": ["*hotel*", "*flight*", "*booking*", "*airbnb*", "*trip*"]
    },
    "בילויים": {
      "keywords": ["סינמה", "קולנוע", "כרטיסים", "חוגים", "פעילות", "STEAM"],
      "patterns": ["*cinema*", "*movie*", "*game*", "*סינמה*", "*קולנוע*"]
    },
    "בריאות": {
      "keywords": ["סופר פארם", "ניו פארם", "בית מרקחת", "קופת חולים", "pharmacy", "health"],
      "patterns": ["*פארם*", "*pharmacy*", "*clinic*", "*health*"]
    },
    "ביגוד והנעלה": {
      "keywords": ["זארה", "H&M", "פוקס", "קסטרו", "נעליים", "בגדים", "clothing", "shoes"],
      "patterns": ["*fashion*", "*shoes*", "*clothing*", "*בגדים*"]
    },
    "קניות אונליין": {
      "keywords": ["אמזון", "עליאקספרס", "איביי", "amazon", "ebay"],
      "patterns": ["*amazon*", "*ebay*", "*aliexpress*"]
    },
    "טיפוח אישי": {
      "keywords": ["מספרה", "ספר", "תספורת", "barber", "hair", "salon"],
      "patterns": ["*salon*", "*beauty*", "*hair*"]
    },
    "חשבונות ומנויים": {
      "keywords": ["חשמל", "ארנונה", "אינטרנט", "סלולרי", "סלקום", "פרטנר", "HOT", "נטפליקס", "ספוטיפי"],
      "patterns": ["*subscription*", "*bill*", "*utility*", "*נטפליקס*", "*spotify*"]
    }
  }
}

# MoneyMate Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://app.supabase.com → Your Project → Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here_very_long_string
SUPABASE_SERVICE_KEY=your_service_role_key_here_KEEP_SECRET

# ============================================
# FLASK CONFIGURATION
# ============================================

# Generate a secure random key:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_256_bit_secret_key_here

# Environment (development or production)
FLASK_ENV=development

# Debug mode (true for development, false for production)
FLASK_DEBUG=true

# Host and port for local development
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

# ============================================
# APPLICATION SETTINGS
# ============================================

# Default language (he or en)
DEFAULT_LANGUAGE=he

# Max file upload size in MB
MAX_UPLOAD_SIZE_MB=16

# Enable AI categorization (optional - requires Ollama)
AI_CATEGORIZATION_ENABLED=false

# ============================================
# PRODUCTION SETTINGS (for Render deployment)
# ============================================
# Uncomment these when deploying to production

# FLASK_ENV=production
# FLASK_DEBUG=false
# FLASK_RUN_HOST=0.0.0.0
# PORT=10000

# ============================================
# OPTIONAL: EMAIL CONFIGURATION (for future features)
# ============================================
# Uncomment and configure if you want to send emails

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_specific_password
# SMTP_FROM_EMAIL=noreply@moneymate.com
# SMTP_FROM_NAME=MoneyMate

# ============================================
# OPTIONAL: ERROR TRACKING (Sentry)
# ============================================
# Uncomment if using Sentry for error tracking

# SENTRY_DSN=https://your_sentry_dsn_here
# SENTRY_ENVIRONMENT=production

# ============================================
# OPTIONAL: FEATURE FLAGS
# ============================================

# Enable shareable dashboards
ENABLE_DASHBOARD_SHARING=true

# Enable data export
ENABLE_DATA_EXPORT=true

# Enable account deletion
ENABLE_ACCOUNT_DELETION=true
